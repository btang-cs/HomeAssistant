page {
  background: linear-gradient(180deg, #eff6ff 0%, #f7fbff 45%, #f8fafc 100%);
  color: #0f172a;
  font-size: 28rpx;
  font-family: "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
}

.container {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 24rpx;
}

.hero {
  border-radius: 30rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #0ea5e9 0%, #2563eb 58%, #1d4ed8 100%);
  box-shadow: 0 12rpx 36rpx rgba(37, 99, 235, 0.25);
}

.hero-title {
  font-size: 38rpx;
  font-weight: 700;
  line-height: 1.3;
}

.hero-desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
}

.stat-row {
  display: flex;
  gap: 14rpx;
  margin-top: 22rpx;
}

.stat-pill {
  flex: 1;
  border-radius: 18rpx;
  padding: 16rpx;
  background: rgba(255, 255, 255, 0.16);
  backdrop-filter: blur(10rpx);
}

.stat-label {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.86);
}

.stat-value {
  display: block;
  margin-top: 6rpx;
  font-size: 34rpx;
  font-weight: 700;
}

.card {
  background: #ffffff;
  border: 1rpx solid #dbeafe;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 18rpx;
  box-shadow: 0 10rpx 24rpx rgba(15, 23, 42, 0.06);
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #0f172a;
}

.subtle {
  color: #64748b;
  font-size: 24rpx;
}

.error-banner {
  margin-top: 16rpx;
  border-radius: 14rpx;
  padding: 14rpx 16rpx;
  background: #fef2f2;
  color: #b91c1c;
  font-size: 24rpx;
}

.empty {
  margin-top: 18rpx;
  border-radius: 16rpx;
  padding: 20rpx;
  text-align: center;
  color: #64748b;
  font-size: 24rpx;
  background: #f8fafc;
}

.list-item {
  margin-top: 18rpx;
  border-radius: 18rpx;
  padding: 18rpx;
  border: 1rpx solid #e2e8f0;
  background: linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
}

.item-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
}

.item-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #0f172a;
}

.item-meta {
  margin-top: 8rpx;
  color: #64748b;
  font-size: 22rpx;
  word-break: break-all;
}

.item-bottom {
  margin-top: 14rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.tag {
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  line-height: 1.6;
}

.tag-on {
  color: #166534;
  background: #dcfce7;
}

.tag-off {
  color: #9a3412;
  background: #ffedd5;
}

.tag-muted {
  color: #334155;
  background: #e2e8f0;
}

.state-block {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

button {
  margin: 0;
  border-radius: 14rpx;
  font-size: 24rpx;
}

.mini-btn {
  min-width: 132rpx;
  padding: 0 16rpx;
  line-height: 1.9;
}

.primary-btn {
  color: #ffffff;
  border: none;
  background: linear-gradient(135deg, #0ea5e9 0%, #2563eb 100%);
}

.secondary-btn {
  color: #1d4ed8;
  border: 1rpx solid #bfdbfe;
  background: #f0f7ff;
}

.danger-btn {
  color: #b91c1c;
  border: 1rpx solid #fecaca;
  background: #fff1f2;
}

.btn-row {
  margin-top: 16rpx;
  display: flex;
  gap: 14rpx;
}

.btn-row button {
  flex: 1;
}

.input-field {
  margin-top: 14rpx;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 14rpx;
  border: 1rpx solid #cbd5e1;
  background: #f8fafc;
  padding: 0 16rpx;
  box-sizing: border-box;
}
